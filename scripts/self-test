#!/usr/bin/env python3
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path.cwd()


def copy_repo(target):
    def ignore(_dir, names):
        return {name for name in names if name == ".git"}

    shutil.copytree(ROOT, target, ignore=ignore, symlinks=True)


def run(cwd, cmd):
    return subprocess.run(
        cmd,
        cwd=cwd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
    )


def expect(cwd, name, cmd, expected_code, contains=None):
    result = run(cwd, cmd)
    ok = result.returncode == expected_code
    if contains is not None:
        ok = ok and contains in result.stdout
    if ok:
        print(f"ok      {name}")
        return True
    print(f"failed  {name}")
    print(result.stdout)
    return False


def replace(path, old, new):
    text = path.read_text()
    if old not in text:
        raise RuntimeError(f"cannot find text in {path}: {old}")
    path.write_text(text.replace(old, new, 1))


def main():
    failures = 0
    with tempfile.TemporaryDirectory(prefix="agentic-template-self-test-") as tmp:
        work = Path(tmp) / "repo"
        copy_repo(work)

        if not expect(work, "baseline repo check passes", ["scripts/project", "repo-check"], 0):
            failures += 1
        if not expect(work, "template unresolved fields are allowed", ["scripts/project", "check-profile"], 0):
            failures += 1

        claude = work / "CLAUDE.md"
        claude.unlink()
        claude.write_text("AGENTS.md\n")
        if not expect(
            work,
            "broken CLAUDE.md symlink fails",
            ["scripts/project", "repo-check"],
            1,
            "CLAUDE.md is not a symlink",
        ):
            failures += 1
        claude.unlink()
        claude.symlink_to("AGENTS.md")
        if not expect(work, "restored CLAUDE.md symlink passes", ["scripts/project", "repo-check"], 0):
            failures += 1

        profile = work / "PROJECT_PROFILE.toon"
        replace(
            profile,
            "\nrejected_options:",
            "\n  - id: malformed_unknown\n    question: Is this malformed?\n\nrejected_options:",
        )
        if not expect(
            work,
            "malformed unknown fails profile validation",
            ["scripts/project", "check-profile"],
            1,
            "Malformed unknown is missing fields",
        ):
            failures += 1
        copy_repo(work.parent / "restore")
        shutil.rmtree(work)
        (work.parent / "restore").rename(work)

        custom = work / "CUSTOMIZE_THIS_PROJECT.toon"
        replace(custom, "status: template", "status: customised")
        if not expect(
            work,
            "customised project with unspecialised profile fails",
            ["scripts/project", "check-profile"],
            1,
            "required specialisation is unresolved",
        ):
            failures += 1
        replace(custom, "status: customised", "status: template")

        if not expect(
            work,
            "unspecialised test command fails clearly",
            ["scripts/project", "test"],
            2,
            "test harness not specialised",
        ):
            failures += 1

    if failures:
        print()
        print(f"SELF TEST FAILED: {failures} failure(s)")
        return 1
    print()
    print("SELF TEST OK")
    return 0


if __name__ == "__main__":
    sys.exit(main())
