project:
  state: template
  confidence: medium
  concept_date: 2026-05-16
  concept_date_reason: original decision date for creating this template

audience:
  skill_level: unknown
  app_shape: unknown
  language_by_role: []
  right_sizing:
    smallest_sufficient: template has no application architecture yet
    deliberately_excluded: []
    revisit_when:
      - project instantiated via /specialise
    bought_in: false

facts:
  - id: template_repository
    observation: repository is a reusable AI-first project template
    evidence:
      - AGENTS.md
      - CUSTOMIZE_THIS_PROJECT.toon
    confidence: high

inferences:
  - id: no_application_runtime_yet
    conclusion: template state intentionally has no Java, Python, Node, Elixir or Godot runtime
    based_on:
      - no_runtime_manifest_present
      - generic_nix_shell
    confidence: high
    validation: run .agentic-template/bin/inspect-project after customisation

decisions:
  - id: project_concept_date
    decision: record 2026-05-16 as the project concept date
    reason:
      - captures the date the project was decided
      - separates project intent metadata from implementation timestamps
    confidence: high
    status: active
    validation:
      - docs/decisions/0001-record-project-concept-date.md
    consequence_if_changed: project origin metadata becomes less clear
  - id: composable_skills
    decision: /specialise orchestrates lazy-loaded bounded skills
    reason:
      - reduces context size
      - avoids one monolithic prompt
    confidence: high
    status: active
    validation:
      - .agents/skills/CATALOG.toon
      - .agents/skills/init/SKILL.md
    consequence_if_changed: init workflow becomes harder to reason about
  - id: mit_template_license
    decision: include MIT license in template state
    reason:
      - permissive default for reusable template
      - /specialise must re-evaluate license fit
    confidence: medium
    status: active
    validation:
      - LICENSE
      - .agents/skills/init/SKILL.md
    consequence_if_changed: downstream projects may need a different license
  - id: truthful_git_provenance
    decision: use real commit author and committer dates
    reason:
      - avoids false project history
      - keeps repository provenance auditable
    confidence: high
    status: active
    validation:
      - AGENTS.md
    consequence_if_changed: history becomes misleading
  - id: canonical_project_script
    decision: use .agentic-template/bin/project as the stable repository command surface
    reason:
      - avoids colliding with downstream projects that already have a Makefile
      - keeps command dispatch testable with Python standard library
      - leaves runtime-specific build tools free for project specialisation
    confidence: high
    status: active
    validation:
      - .agentic-template/bin/project --list
      - .agentic-template/bin/project check
    consequence_if_changed: generated projects may inherit confusing or conflicting command wrappers
  - id: repository_local_knowledge_layer
    decision: use .agents/knowledge for durable knowledge, proposals and graph-like relationships
    reason:
      - preserves HANDOFF.toon as active task state
      - keeps Superpowers focused on engineering workflow
      - gives agents searchable local context without external infrastructure
    confidence: high
    status: active
    validation:
      - .agents/knowledge/README.md
      - .agentic-template/bin/check-knowledge
    consequence_if_changed: agents may duplicate guidance or lose durable learnings between sessions

unknowns:
  - id: target_project_domain
    question: What domain and users will a generated project serve?
    why_it_matters:
      - affects architecture recommendation
      - affects test harness risks
      - affects persistence and integration choices
    evidence: []
    working_assumption: unknown_until_template_instantiated
    consequence_if_wrong: /specialise may recommend the wrong thin slice
    blocking: false
    validation:
      - inspect CUSTOMIZE_THIS_PROJECT.toon
      - inspect repository evidence
      - ask smallest useful question set
    status: open
  - id: application_runtime
    question: Which runtime and framework does the instantiated project need?
    why_it_matters:
      - determines dev shell extensions
      - determines test harness
      - determines build container strategy
    evidence: []
    working_assumption: infer_from_repository_evidence
    consequence_if_wrong: build and test commands may be specialised incorrectly
    blocking: false
    validation:
      - .agentic-template/bin/inspect-project
      - discovery runtime skills
    status: open

rejected_options:
  - id: monolithic_init_prompt
    option: put all runtime and infrastructure instructions into /specialise
    reason_rejected:
      - wastes context
      - makes project intelligence harder to evolve
    evidence:
      - .agents/skills/CATALOG.toon
  - id: default_platform_stack
    option: include Kafka, Redis, database, Kubernetes or LocalStack by default
    reason_rejected:
      - no template-state evidence justifies them
      - increases decision fatigue
    evidence:
      - compose.yaml
  - id: template_makefile_facade
    option: keep a template Makefile as the canonical command facade
    reason_rejected:
      - can conflict with legitimate downstream project Makefiles
      - Make target hierarchies can hide behaviour and confuse agents
      - .agentic-template/bin/project is explicit and directly testable
    evidence:
      - .agentic-template/bin/project

architecture:
  application_shape: unknown
  language: unknown
  framework: unknown
  build_system: unknown
  integrations:
    messaging: none_known
    external_services: []
  persistence:
    kind: unknown
    provider: unknown

testing:
  harness: unspecialised
  layers: []
  test_first: true
  philosophy: testing_trophy

containers:
  application_image: not_applicable
  reason: template repository has no deployable application runtime
  image_test: not_applicable
  compose: minimal_template

infrastructure:
  local_topology: nix
  deployment_target: unknown
  iac:
    status: deferred
    tool: null
    validation_command: null
    revisit_trigger: deployment target selected during project instantiation

tooling:
  superpowers:
    status: detect
  mcp:
    required: []
    optional: []
  knowledge:
    location: .agents/knowledge
    validator: .agentic-template/bin/check-knowledge
    promotion: inbox_then_review
