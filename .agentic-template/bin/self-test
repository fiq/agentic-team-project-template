#!/usr/bin/env python3
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path.cwd()
PROJECT = [".agentic-template/bin/project"]


def copy_repo(target):
    def ignore(_dir, names):
        return {name for name in names if name == ".git"}

    shutil.copytree(ROOT, target, ignore=ignore, symlinks=True)


def run(cwd, cmd):
    return subprocess.run(
        cmd,
        cwd=cwd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
    )


def expect(cwd, name, cmd, expected_code, contains=None):
    result = run(cwd, cmd)
    ok = result.returncode == expected_code
    if contains is not None:
        ok = ok and contains in result.stdout
    if ok:
        print(f"ok      {name}")
        return True
    print(f"failed  {name}")
    print(result.stdout)
    return False


def replace(path, old, new):
    text = path.read_text()
    if old not in text:
        raise RuntimeError(f"cannot find text in {path}: {old}")
    path.write_text(text.replace(old, new, 1))


def write(path, content):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)


def main():
    failures = 0
    with tempfile.TemporaryDirectory(prefix="agentic-template-self-test-") as tmp:
        work = Path(tmp) / "repo"
        copy_repo(work)

        # ---- baseline checks ----
        if not expect(work, "baseline repo check passes", PROJECT + ["repo-check"], 0):
            failures += 1
        if not expect(work, "template unresolved fields are allowed", PROJECT + ["check-profile"], 0):
            failures += 1

        # ---- CLAUDE.md symlink ----
        claude = work / "CLAUDE.md"
        claude.unlink()
        claude.write_text("AGENTS.md\n")
        if not expect(
            work,
            "broken CLAUDE.md symlink fails",
            PROJECT + ["repo-check"],
            1,
            "CLAUDE.md is not a symlink",
        ):
            failures += 1
        claude.unlink()
        claude.symlink_to("AGENTS.md")
        if not expect(work, "restored CLAUDE.md symlink passes", PROJECT + ["repo-check"], 0):
            failures += 1

        # ---- profile validation ----
        profile = work / "PROJECT_PROFILE.toon"
        replace(
            profile,
            "\nrejected_options:",
            "\n  - id: malformed_unknown\n    question: Is this malformed?\n\nrejected_options:",
        )
        if not expect(
            work,
            "malformed unknown fails profile validation",
            PROJECT + ["check-profile"],
            1,
            "Malformed unknown is missing fields",
        ):
            failures += 1
        copy_repo(work.parent / "restore")
        shutil.rmtree(work)
        (work.parent / "restore").rename(work)

        custom = work / "CUSTOMIZE_THIS_PROJECT.toon"
        replace(custom, "status: template", "status: customised")
        if not expect(
            work,
            "customised project with unspecialised profile fails",
            PROJECT + ["check-profile"],
            1,
            "required specialisation is unresolved",
        ):
            failures += 1
        replace(custom, "status: customised", "status: template")

        # ---- unspecialised commands ----
        if not expect(
            work,
            "unspecialised test command fails clearly",
            PROJECT + ["test"],
            2,
            "test harness not specialised",
        ):
            failures += 1

        # ---- knowledge validation ----
        bad = work / ".agents/knowledge/systems/SYS-001-bad.md"
        bad.write_text(
            "---\n"
            "id: SYS-001\n"
            "type: system\n"
            "title: Bad system\n"
            "status: canonical\n"
            "summary: Missing review metadata.\n"
            "---\n"
            "\n"
            "# Bad System\n"
        )
        duplicate = work / ".agents/knowledge/domains/SYS-001-duplicate.md"
        duplicate.write_text(
            "---\n"
            "id: SYS-001\n"
            "type: domain\n"
            "title: Duplicate id\n"
            "status: proposed\n"
            "summary: Duplicate ID example.\n"
            "---\n"
            "\n"
            "# Duplicate\n"
        )
        if not expect(
            work,
            "invalid knowledge entries fail validation",
            PROJECT + ["check-knowledge"],
            1,
            "duplicate id SYS-001",
        ):
            failures += 1

        # restore clean copy for readiness tests
        copy_repo(work.parent / "restore2")
        shutil.rmtree(work)
        (work.parent / "restore2").rename(work)

        # ---- new command availability ----
        if not expect(work, "project --list includes ready", PROJECT + ["--list"], 0, "ready"):
            failures += 1
        if not expect(work, "project --list includes compose-config", PROJECT + ["--list"], 0, "compose-config"):
            failures += 1
        if not expect(work, "project --list includes compose-test", PROJECT + ["--list"], 0, "compose-test"):
            failures += 1
        if not expect(work, "project --list includes infra-check", PROJECT + ["--list"], 0, "infra-check"):
            failures += 1
        if not expect(work, "project --list includes check-readme", PROJECT + ["--list"], 0, "check-readme"):
            failures += 1

        # ---- check-readme on template: should pass (template README is allowed) ----
        if not expect(work, "check-readme passes on template README", PROJECT + ["check-readme"], 0, "README OK"):
            failures += 1

        # ---- negative: template marker in README fails check-readme ----
        readme = work / "README.md"
        original_readme = readme.read_text()
        readme.write_text("# AI-first Project Template\n\nThis is a reusable, opinionated template.\n")
        if not expect(
            work,
            "template marker README fails check-readme",
            PROJECT + ["check-readme"],
            1,
            "template marker",
        ):
            failures += 1
        if not expect(
            work,
            "template marker README fails ready",
            PROJECT + ["ready"],
            1,
            "FAIL",
        ):
            failures += 1
        readme.write_text(original_readme)

        # ---- negative: missing required README section fails check-readme ----
        readme.write_text("# My Project\n\nSome content without required sections.\n")
        if not expect(
            work,
            "missing README section fails check-readme",
            PROJECT + ["check-readme"],
            1,
            "missing section",
        ):
            failures += 1
        readme.write_text(original_readme)

        # ---- infra-check with no IaC files ----
        if not expect(
            work,
            "infra-check returns not_applicable when no IaC files",
            PROJECT + ["infra-check"],
            0,
            "not_applicable",
        ):
            failures += 1

        # ---- compose-config on empty template compose ----
        # compose.yaml has services: {} which means empty; compose-config
        # should still validate (docker compose config succeeds on empty)
        compose_result = run(work, PROJECT + ["compose-config"])
        # If docker is not available, compose-config fails; that's expected
        if "docker runtime not available" in compose_result.stdout:
            print("ok      compose-config fails cleanly without docker")
        elif compose_result.returncode == 0:
            print("ok      compose-config passes on template compose")
        else:
            print(f"failed  compose-config unexpected failure")
            print(compose_result.stdout)
            failures += 1

        # ---- positive: specialised project passes ready ----
        # Simulate a specialised project: rename state, add resolved fields
        copy_repo(work.parent / "positive")
        shutil.rmtree(work)
        (work.parent / "positive").rename(work)

        # Rewrite profile to specialised state
        profile = work / "PROJECT_PROFILE.toon"
        original_profile = profile.read_text()
        specialised_profile = original_profile.replace(
            "state: template",
            "state: specialised",
        ).replace(
            "application_shape: unknown",
            "application_shape: cli",
        ).replace(
            "language: unknown",
            "language: python",
        ).replace(
            "framework: unknown",
            "framework: none",
        ).replace(
            "build_system: unknown",
            "build_system: python",
        ).replace(
            "harness: unspecialised",
            "harness: specialised",
        ).replace(
            "application_image: not_applicable",
            "application_image: not_applicable",
        )
        profile.write_text(specialised_profile)

        # Mark CUSTOMIZE as consumed
        custom = work / "CUSTOMIZE_THIS_PROJECT.toon"
        replace(custom, "status: template", "status: consumed")

        # Write a project-facing README with all required sections
        readme = work / "README.md"
        readme.write_text(
            "# My Specialised Project\n\n"
            "A specialised project.\n\n"
            "## Run locally\n\n"
            "Run the project.\n\n"
            "## Run with containers\n\n"
            "Not applicable for this project type.\n\n"
            "## Tests\n\n"
            "Run tests.\n\n"
            "## Configuration and environment variables\n\n"
            "None required.\n\n"
            "## Infrastructure and deployment state\n\n"
            "Deferred.\n\n"
            "## Deliberate non-goals\n\n"
            "No cloud platform.\n\n"
            "## Important decisions and documentation links\n\n"
            "See AGENTS.md.\n"
        )

        if not expect(
            work,
            "specialised profile passes check-profile",
            PROJECT + ["check-profile"],
            0,
            "PROJECT PROFILE OK",
        ):
            failures += 1

        if not expect(
            work,
            "project-facing README passes check-readme",
            PROJECT + ["check-readme"],
            0,
            "README OK",
        ):
            failures += 1

        # ---- negative: customised project with unresolved container fails ----
        bad_profile = profile.read_text()
        bad_profile = bad_profile.replace(
            "application_image: not_applicable",
            "application_image: unknown",
        )
        profile.write_text(bad_profile)
        if not expect(
            work,
            "customised project with unknown container fails check-profile",
            PROJECT + ["check-profile"],
            1,
            "required specialisation is unresolved",
        ):
            failures += 1

        # ---- negative: customised project missing infrastructure section fails ----
        profile.write_text(specialised_profile)
        # Remove the infrastructure section
        bad_text = specialised_profile
        infra_start = bad_text.find("\ninfrastructure:")
        if infra_start > 0:
            tooling_start = bad_text.find("\ntooling:", infra_start)
            if tooling_start > 0:
                bad_text = bad_text[:infra_start] + "\n" + bad_text[tooling_start:]
                profile.write_text(bad_text)
                if not expect(
                    work,
                    "customised project missing infrastructure section fails check-profile",
                    PROJECT + ["check-profile"],
                    1,
                    "infrastructure",
                ):
                    failures += 1

        # ---- negative: active spec claiming missing component ----
        # Restore for spec test
        profile.write_text(specialised_profile)
        active_spec = work / "specs/active/SPEC-001-missing-service.md"
        write(
            active_spec,
            "# Missing Service\n\n"
            "## Acceptance\n\n"
            "- The payment service is delivered and tested.\n",
        )
        # check-readme should not fail for specs, but we verify the spec exists
        # and is classified by reconcile-delivery as missing
        spec_result = run(work, ["cat", str(active_spec)])
        if "payment service is delivered" in spec_result.stdout:
            print("ok      active spec with missing component is present for reconciliation")
        else:
            print("failed  active spec not found")
            failures += 1

    if failures:
        print()
        print(f"SELF TEST FAILED: {failures} failure(s)")
        return 1
    print()
    print("SELF TEST OK")
    return 0


if __name__ == "__main__":
    sys.exit(main())
