#!/usr/bin/env python3
from pathlib import Path
import os
import subprocess
import sys

ROOT = Path.cwd()

REQUIRED_FILES = [
    "AGENTS.md",
    "CLAUDE.md",
    "HANDOFF.toon",
    "PROJECT_PROFILE.toon",
    "CUSTOMIZE_THIS_PROJECT.toon",
    "README.md",
    "LICENSE",
    "flake.nix",
    "flake.lock",
    "compose.yaml",
    ".agents/skills/CATALOG.toon",
    ".agents/skills/init/SKILL.md",
    ".agents/knowledge/README.md",
    ".agents/knowledge/index.md",
    ".agents/schemas/knowledge-entry.schema.md",
    ".agents/schemas/handoff.schema.md",
    ".agents/schemas/learning-proposal.schema.md",
    ".agents/team/knowledge-curator.md",
    ".agents/coordination/COMMUNICATION_POLICY.md",
    ".agents/coordination/MODEL_ROUTING_POLICY.md",
    "specs/templates/feature.md",
    "docs/wiki/index.md",
    ".github/workflows/ci.yml",
    ".github/copilot-instructions.md",
    ".worktrees/.gitkeep",
    ".worktrees/README.md",
    ".agentic-template/bin/bootstrap-project",
    ".agentic-template/bin/project",
    ".agentic-template/bin/inspect-project",
    ".agentic-template/bin/check-project-profile",
    ".agentic-template/bin/check-repo-contract",
    ".agentic-template/bin/check-handoff",
    ".agentic-template/bin/check-knowledge",
    ".agentic-template/bin/check-tooling",
    ".agentic-template/bin/check-mcp",
    ".agentic-template/bin/check-readme",
    ".agentic-template/bin/project-ready",
    ".agentic-template/bin/compose-config",
    ".agentic-template/bin/compose-test",
    ".agentic-template/bin/infra-check",
    ".agentic-template/bin/doctor",
    ".agentic-template/bin/self-test",
]

REQUIRED_EXECUTABLES = [
    rel for rel in REQUIRED_FILES if rel.startswith(".agentic-template/bin/")
]

REQUIRED_SKILLS = [
    "discovery/detect-runtime",
    "discovery/detect-application-shape",
    "discovery/detect-messaging",
    "discovery/detect-persistence",
    "discovery/detect-infrastructure",
    "specialise/runtime-node",
    "specialise/runtime-java",
    "specialise/runtime-python",
    "specialise/runtime-elixir",
    "specialise/runtime-godot",
    "specialise/messaging-kafka",
    "specialise/sql-migrations",
    "specialise/test-harness",
    "specialise/container-build",
    "specialise/infra-local-compose",
    "specialise/infra-decision",
    "specialise/ci",
    "workflow/test-first",
    "workflow/reassess-project-profile",
    "workflow/handoff-maintenance",
    "workflow/reconcile-delivery",
    "coordination/team-selection",
    "coordination/agent-team-fallback",
    "knowledge/knowledge-search",
    "knowledge/knowledge-capture",
    "tooling/detect-mcp",
    "tooling/detect-superpowers",
    "tooling/model-routing",
]

PROJECT_COMMANDS = [
    "help", "init", "inspect", "check", "test", "contract-test",
    "integration-test", "component-test", "e2e-test", "lint", "run",
    "image", "image-test", "repo-check", "check-profile", "check-handoff",
    "check-knowledge", "check-tooling", "check-mcp", "check-readme",
    "ready", "compose-config", "compose-test", "infra-check",
    "doctor", "self-test",
]

def fail(lines):
    print("REPO CONTRACT FAILED")
    print()
    for line in lines:
        print("- " + line)
    return 1

def check_skill_frontmatter(path):
    text = path.read_text()
    if not text.startswith("---\n"):
        return "missing frontmatter"
    end = text.find("\n---", 4)
    if end < 0:
        return "unterminated frontmatter"
    frontmatter = text[4:end]
    if "\nname:" not in "\n" + frontmatter:
        return "frontmatter missing name"
    if "\ndescription:" not in "\n" + frontmatter:
        return "frontmatter missing description"
    return None

def main():
    errors = []
    for rel in REQUIRED_FILES:
        if not (ROOT / rel).exists():
            errors.append(f"missing {rel}")
    for rel in REQUIRED_EXECUTABLES:
        path = ROOT / rel
        if path.exists() and not os.access(path, os.X_OK):
            errors.append(f"{rel} is not executable")
    claude = ROOT / "CLAUDE.md"
    if not claude.is_symlink():
        errors.append("CLAUDE.md is not a symlink")
    elif os.readlink(claude) != "AGENTS.md":
        errors.append("CLAUDE.md does not link to AGENTS.md")
    for skill in REQUIRED_SKILLS:
        skill_path = ROOT / ".agents/skills" / skill / "SKILL.md"
        if not skill_path.exists():
            errors.append(f"missing skill {skill}")
    for skill_path in sorted((ROOT / ".agents/skills").rglob("SKILL.md")):
        problem = check_skill_frontmatter(skill_path)
        if problem:
            errors.append(f"{skill_path.relative_to(ROOT)} {problem}")
    project_script = ROOT / ".agentic-template/bin/project"
    if project_script.exists():
        result = subprocess.run(
            [str(project_script), "--list"],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
        )
        if result.returncode:
            errors.append(".agentic-template/bin/project --list failed")
        else:
            commands = set(result.stdout.splitlines())
            for command in PROJECT_COMMANDS:
                if command not in commands:
                    errors.append(f".agentic-template/bin/project missing command {command}")
    if errors:
        return fail(errors)
    print("REPO CONTRACT OK")
    return 0

if __name__ == "__main__":
    sys.exit(main())
