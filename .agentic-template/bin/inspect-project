#!/usr/bin/env python3
import argparse
import json
from pathlib import Path

ROOT = Path.cwd()

PATTERNS = {
    "node": [
        "package.json",
        "pnpm-lock.yaml",
        "package-lock.json",
        "yarn.lock",
        "bun.lockb",
        "tsconfig.json",
    ],
    "java": ["pom.xml", "build.gradle", "build.gradle.kts", "gradlew", "mvnw"],
    "python": ["pyproject.toml", "uv.lock", "poetry.lock", "requirements.txt"],
    "elixir": ["mix.exs", "mix.lock"],
    "godot": ["project.godot", "export_presets.cfg"],
    "containers": [
        "Dockerfile",
        "Containerfile",
        ".dockerignore",
        "compose.yaml",
        "docker-compose.yml",
    ],
    "ci": [".github/workflows/ci.yml", ".github/workflows/repo-contract.yml"],
    "agent_tooling": [
        "AGENTS.md",
        "CLAUDE.md",
        ".claude",
        ".codex",
        ".agents/skills/CATALOG.toon",
    ],
}

TEXT_HINTS = {
    "react": ["react"],
    "next": ["next"],
    "spring_boot": ["spring-boot", "@SpringBootApplication"],
    "quarkus": ["quarkus"],
    "kafka": ["kafka", "@KafkaListener", "KafkaConsumer", "KafkaProducer"],
    "langchain": ["langchain", "langgraph"],
    "langchain4j": ["langchain4j"],
    "fastapi": ["fastapi", "FastAPI"],
    "django": ["django"],
    "flask": ["flask"],
    "sql": [
        "postgres",
        "mysql",
        "mariadb",
        "sqlite",
        "jdbc",
        "sqlalchemy",
        "ecto",
    ],
    "migrations": ["flyway", "liquibase", "alembic", "priv/repo/migrations"],
    "redis": ["redis"],
    "mongodb": ["mongodb", "mongo"],
    "supabase": ["supabase"],
    "aws": ["aws", "ecs", "eks", "lambda", "s3", "rds", "dynamodb", "sqs", "sns", "msk"],
    "fly": ["fly.toml"],
}

TEMPLATE_DIRS = {
    ".agents",
    ".claude",
    ".codex",
    ".git",
    ".github",
    "docs",
    "nix",
    "scripts",
    "specs",
}

APPLICATION_DIRS = {
    "app",
    "apps",
    "cmd",
    "config",
    "lib",
    "packages",
    "priv",
    "src",
    "test",
    "tests",
    "web",
}

ROOT_TEXT_FILES = {
    "package.json",
    "pom.xml",
    "build.gradle",
    "build.gradle.kts",
    "pyproject.toml",
    "requirements.txt",
    "mix.exs",
    "project.godot",
    "fly.toml",
    "Dockerfile",
    "Containerfile",
}


def exists(path):
    return (ROOT / path).exists()


def is_application_evidence(path):
    rel = path.relative_to(ROOT)
    parts = rel.parts
    if not parts:
        return False
    if parts[0] in TEMPLATE_DIRS:
        return False
    if len(parts) == 1 and parts[0] in ROOT_TEXT_FILES:
        return True
    return parts[0] in APPLICATION_DIRS


def scan_text():
    hits = {name: [] for name in TEXT_HINTS}
    for path in ROOT.rglob("*"):
        if not path.is_file() or not is_application_evidence(path):
            continue
        if path.stat().st_size > 500_000:
            continue
        try:
            text = path.read_text(errors="ignore").lower()
        except OSError:
            continue
        rel = str(path.relative_to(ROOT))
        for name, needles in TEXT_HINTS.items():
            if any(needle.lower() in text for needle in needles):
                hits[name].append(rel)
    return {k: sorted(set(v)) for k, v in hits.items() if v}


def inspect():
    files = {
        key: [p for p in paths if exists(p)]
        for key, paths in PATTERNS.items()
    }
    return {
        "files": {k: v for k, v in files.items() if v},
        "application_text_hints": scan_text(),
    }


def print_human(evidence):
    print("PROJECT INSPECTION")
    print()
    print("files")
    for name, paths in evidence["files"].items():
        print(f"  {name}")
        for path in paths:
            print(f"    - {path}")
    if not evidence["files"]:
        print("  none")
    print()
    print("application text hints")
    if evidence["application_text_hints"]:
        for name, paths in evidence["application_text_hints"].items():
            print(f"  {name}")
            for path in paths:
                print(f"    - {path}")
    else:
        print("  none")
    print()
    print("note")
    print("  Template docs, skills and scripts are not treated as application runtime evidence.")


def main():
    parser = argparse.ArgumentParser(description="Print compact project evidence")
    parser.add_argument("--json", action="store_true", help="print machine-readable evidence")
    args = parser.parse_args()

    evidence = inspect()
    if args.json:
        print(json.dumps(evidence, indent=2, sort_keys=True))
    else:
        print_human(evidence)


if __name__ == "__main__":
    main()
