#!/usr/bin/env python3
import argparse
from pathlib import Path
import subprocess
import sys

BIN = Path(__file__).resolve().parent
COMMAND_NAME = ".agentic-template/bin/project"

COMMANDS = {
    "init": [[str(BIN / "bootstrap-project")]],
    "inspect": [[str(BIN / "inspect-project")]],
    "check": [
        [str(BIN / "check-repo-contract")],
        [str(BIN / "check-project-profile")],
        [str(BIN / "check-handoff")],
        [str(BIN / "check-tooling")],
        [str(BIN / "check-mcp")],
    ],
    "repo-check": [[str(BIN / "check-repo-contract")]],
    "check-profile": [[str(BIN / "check-project-profile")]],
    "check-handoff": [[str(BIN / "check-handoff")]],
    "check-tooling": [[str(BIN / "check-tooling")]],
    "check-mcp": [[str(BIN / "check-mcp")]],
    "doctor": [[str(BIN / "doctor")]],
    "self-test": [[str(BIN / "self-test")]],
}

UNSPECIALISED = {
    "test",
    "contract-test",
    "integration-test",
    "component-test",
    "e2e-test",
    "lint",
    "run",
    "image",
    "image-test",
}


def print_help():
    print(f"Usage: {COMMAND_NAME} <command> [args...]")
    print()
    print("Commands:")
    for name in sorted(COMMANDS):
        print(f"  {name}")
    for name in sorted(UNSPECIALISED):
        print(f"  {name}  (specialise during init)")


def run_many(commands):
    for command in commands:
        result = subprocess.run(command)
        if result.returncode:
            return result.returncode
    return 0


def fail_unspecialised(command):
    print("ERROR")
    print()
    print(f"{command} harness not specialised")
    print()
    print("next:")
    print(f"  {COMMAND_NAME} init")
    print("project state:")
    print("  testing.harness = unspecialised")
    return 2


def main(argv):
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--list", action="store_true")
    parser.add_argument("command", nargs="?")
    parser.add_argument("args", nargs=argparse.REMAINDER)
    args = parser.parse_args(argv)

    if args.list:
        for name in sorted(set(COMMANDS) | UNSPECIALISED | {"help"}):
            print(name)
        return 0

    if args.command in {None, "help", "--help", "-h"}:
        print_help()
        return 0

    if args.command in UNSPECIALISED:
        return fail_unspecialised(args.command)

    command = COMMANDS.get(args.command)
    if command is None:
        print("ERROR")
        print()
        print(f"unknown command: {args.command}")
        print()
        print("Run:")
        print(f"  {COMMAND_NAME} help")
        return 2

    if args.args and len(command) > 1:
        print("ERROR")
        print()
        print(f"{args.command} does not accept extra arguments")
        return 2

    if args.args:
        command = [command[0] + args.args]
    return run_many(command)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
