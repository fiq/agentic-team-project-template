#!/usr/bin/env python3
import argparse
from pathlib import Path
import subprocess

BIN = Path(__file__).resolve().parent
PROJECT = ".agentic-template/bin/project"

def main():
    parser = argparse.ArgumentParser(description="Evidence-driven project bootstrap")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--validate-only", action="store_true")
    args = parser.parse_args()

    print("INIT", flush=True)
    print(flush=True)
    print("phases: discover -> decide -> specialise -> rewrite identity -> validate -> update handoff", flush=True)
    print(flush=True)
    print("reading AGENTS.md, HANDOFF.toon, PROJECT_PROFILE.toon and CUSTOMIZE_THIS_PROJECT.toon", flush=True)
    print("loading .agents/skills/CATALOG.toon", flush=True)
    print("inspecting repository evidence", flush=True)
    subprocess.run([str(BIN / "inspect-project")], check=False)
    print()
    print("RECOMMENDATION")
    print()
    print("Template state has no application runtime yet. Keep architecture")
    print("unspecialised, capture unknowns, and run /init again after adding")
    print("project evidence.")
    print()
    print("The /init agent workflow owns evidence-based edits. This CLI assists")
    print("with inspection and validation but does not perform specialisation.")
    print()
    print("POSTCONDITIONS (enforced by project ready)")
    print()
    print("- PROJECT_PROFILE.toon project state is not 'template'")
    print("- README.md is project-facing")
    print("- AGENTS.md is project-facing")
    print("- CUSTOMIZE_THIS_PROJECT.toon is marked consumed or historical")
    print("- runtime, testing, container, infrastructure and CI decisions are explicit")
    print("- applicable repository commands are specialised")
    print("- non-applicable commands are explicitly recorded as such")
    print("- HANDOFF.toon points to real project work")
    print()
    print("NEXT")
    print()
    print("- update CUSTOMIZE_THIS_PROJECT.toon with project intent if known")
    print("- add real project files or source evidence")
    print(f"- run {PROJECT} init again")
    if args.dry_run:
        print()
        print("dry-run: no files changed")
    if args.validate_only:
        return subprocess.run([str(BIN / "project"), "check"]).returncode
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
