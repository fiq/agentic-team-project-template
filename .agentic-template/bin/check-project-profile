#!/usr/bin/env python3
from pathlib import Path
import sys

ROOT = Path.cwd()
PROFILE = ROOT / "PROJECT_PROFILE.toon"
CUSTOM = ROOT / "CUSTOMIZE_THIS_PROJECT.toon"

REQUIRED_SECTIONS = [
    "project:",
    "audience:",
    "facts:",
    "inferences:",
    "decisions:",
    "unknowns:",
    "rejected_options:",
    "architecture:",
    "testing:",
    "containers:",
    "infrastructure:",
    "tooling:",
]

UNKNOWN_FIELDS = [
    "id:",
    "question:",
    "why_it_matters:",
    "evidence:",
    "working_assumption:",
    "consequence_if_wrong:",
    "blocking:",
    "validation:",
    "status:",
]

def fail(msg):
    print("ERROR")
    print()
    print(msg)
    return 1

def section_block(text, section):
    start = text.find(section)
    if start < 0:
        return ""
    next_positions = [text.find("\n" + s, start + 1) for s in REQUIRED_SECTIONS if text.find("\n" + s, start + 1) > 0]
    end = min(next_positions) if next_positions else len(text)
    return text[start:end]

def main():
    if not PROFILE.exists():
        return fail("PROJECT_PROFILE.toon missing")
    text = PROFILE.read_text()
    missing = [s for s in REQUIRED_SECTIONS if s not in text]
    if missing:
        return fail("PROJECT_PROFILE.toon missing sections: " + ", ".join(missing))

    unknowns = section_block(text, "unknowns:")
    if "\n  - id:" in unknowns:
        blocks = unknowns.split("\n  - id:")[1:]
        for block in blocks:
            candidate = "id:" + block
            missing_fields = [f for f in UNKNOWN_FIELDS if f not in candidate]
            if missing_fields:
                return fail("Malformed unknown is missing fields: " + ", ".join(missing_fields))

    if CUSTOM.exists():
        custom = CUSTOM.read_text()
        customised = (
            "status: customised" in custom
            or "status: customized" in custom
            or "status: consumed" in custom
        )
        if customised:
            unresolved = []
            for marker in [
                "application_shape: unknown",
                "language: unknown",
                "framework: unknown",
                "build_system: unknown",
                "harness: unspecialised",
                "application_image: unknown",
            ]:
                if marker in text:
                    unresolved.append(marker)
            if unresolved:
                return fail(
                    "Project marked customised while required specialisation is unresolved: "
                    + ", ".join(unresolved)
                )

    # Audience calibration must exist. Template state may leave it unresolved,
    # but a specialised project must record skill level, app shape and an
    # explicit, bought-into right-sizing decision.
    audience_block = section_block(text, "audience:")
    for field in ["skill_level:", "app_shape:", "right_sizing:"]:
        if field not in audience_block:
            return fail("PROJECT_PROFILE.toon audience section is missing " + field)
    if "state: template" not in text:
        for marker in ["skill_level: unknown", "app_shape: unknown"]:
            if marker in audience_block:
                return fail(
                    "Specialised project has unresolved audience calibration: " + marker
                )
        if "bought_in: false" in audience_block:
            return fail(
                "Specialised project has no bought-into right-sizing decision "
                "(audience.right_sizing.bought_in is false)"
            )

    # Template state is allowed to have unresolved decisions, but the
    # infrastructure section must exist so the decision is explicit after
    # specialisation.
    if "state: template" not in text:
        infra_block = section_block(text, "infrastructure:")
        if "iac:" not in infra_block:
            return fail(
                "PROJECT_PROFILE.toon infrastructure section is missing iac decision"
            )
        if "local_topology:" not in infra_block:
            return fail(
                "PROJECT_PROFILE.toon infrastructure section is missing local_topology"
            )
        if "deployment_target:" not in infra_block:
            return fail(
                "PROJECT_PROFILE.toon infrastructure section is missing deployment_target"
            )

    print("PROJECT PROFILE OK")
    return 0

if __name__ == "__main__":
    sys.exit(main())
