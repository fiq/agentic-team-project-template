#!/usr/bin/env python3
"""Deterministic readiness check.

Runs all applicable deterministic checks and prints a clear
PASS / NOT APPLICABLE / FAIL summary.

A skipped unresolved decision is FAIL, not NOT APPLICABLE.
"""
from pathlib import Path
import subprocess
import sys

ROOT = Path.cwd()
BIN = Path(__file__).resolve().parent
COMMAND_NAME = ".agentic-template/bin/project"


def read_profile():
    profile = ROOT / "PROJECT_PROFILE.toon"
    if not profile.exists():
        return ""
    return profile.read_text()


def has_docker():
    result = subprocess.run(
        ["sh", "-c", "command -v docker >/dev/null 2>&1"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return result.returncode == 0


def has_compose_file():
    compose = ROOT / "compose.yaml"
    if not compose.exists():
        return False
    try:
        text = compose.read_text()
    except OSError:
        return False
    return "services: {}" not in text and "services: {}" not in text.replace(" ", "")


def has_dockerfile():
    return (ROOT / "Dockerfile").exists() or (ROOT / "Containerfile").exists()


def run(cmd, label):
    result = subprocess.run(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
    )
    return label, result


def main():
    profile = read_profile()
    is_template = "state: template" in profile
    docker_available = has_docker()
    compose_present = has_compose_file()
    dockerfile_present = has_dockerfile()

    # Always-applicable checks.
    steps = [
        (["sh", "-c", "git diff --check"], "git diff --check"),
        ([str(BIN / "check-repo-contract")], "repository contract"),
        ([str(BIN / "check-project-profile")], "project profile"),
        ([str(BIN / "check-handoff")], "handoff"),
        ([str(BIN / "check-knowledge")], "knowledge"),
        ([str(BIN / "check-readme")], "documentation"),
    ]

    # Tests and lint are unspecialised in template state; only run if
    # specialised. We detect specialisation by checking whether the
    # `project` dispatcher still treats them as unspecialised.
    project_script = str(BIN / "project")
    specialised_commands = set()
    list_result = subprocess.run(
        [project_script, "--list"],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
    )
    if list_result.returncode == 0:
        specialised_commands = set(list_result.stdout.split())

    if not is_template:
        if "test" in specialised_commands:
            steps.append(([project_script, "test"], "unit tests"))
        if "lint" in specialised_commands:
            steps.append(([project_script, "lint"], "lint"))
        if "integration-test" in specialised_commands:
            steps.append(([project_script, "integration-test"], "integration tests"))
        if "contract-test" in specialised_commands:
            steps.append(([project_script, "contract-test"], "contract tests"))

    # Container checks.
    if is_template:
        pass
    elif dockerfile_present and docker_available:
        if "image-test" in specialised_commands:
            steps.append(([project_script, "image-test"], "container image test"))
        elif "image" in specialised_commands:
            steps.append(([project_script, "image"], "container image build"))
        else:
            steps.append(([project_script, "image"], "container image build"))
    elif dockerfile_present and not docker_available:
        steps.append(None)  # placeholder handled below

    # Compose checks.
    if not is_template and compose_present and docker_available:
        steps.append(([project_script, "compose-config"], "compose config"))
        if "compose-test" in specialised_commands:
            steps.append(([project_script, "compose-test"], "compose test"))

    # Infra checks.
    if not is_template and "infra-check" in specialised_commands:
        steps.append(([project_script, "infra-check"], "infra check"))

    passed = []
    failed = []
    not_applicable = []

    for step in steps:
        if step is None:
            not_applicable.append(
                ("container image test", "docker runtime unavailable")
            )
            continue
        cmd, label = step
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
        )
        if result.returncode == 0:
            passed.append(label)
        else:
            print(f"--- {label} ---")
            print(result.stdout.strip())
            print()
            failed.append((label, result.returncode))

    # Not-applicable determinations.
    if is_template:
        not_applicable.append(("container image", "template state: no application image"))
        not_applicable.append(("compose test", "template state: empty compose"))
        not_applicable.append(("infra check", "template state: no deployment target"))

    if not is_template and not dockerfile_present:
        container_state = containers_resolved(profile)
        if container_state == "not_applicable":
            not_applicable.append(
                ("container image", "containerisation recorded as not_applicable")
            )
        elif container_state == "unknown":
            failed.append(
                ("container decision", "container decision is unknown, not not_applicable")
            )
        else:
            not_applicable.append(("container image", "no Dockerfile; container decision recorded"))

    if not is_template and not compose_present:
        not_applicable.append(("compose test", "compose topology empty by project decision"))

    if not is_template and not docker_available and not compose_present and not dockerfile_present:
        pass

    print("SUMMARY")
    print()
    print(f"PASS             {len(passed)}")
    print(f"NOT APPLICABLE   {len(not_applicable)}")
    print(f"FAIL             {len(failed)}")
    print()
    if passed:
        print("PASSED")
        for label in passed:
            print(f"  - {label}")
        print()
    if not_applicable:
        print("NOT APPLICABLE")
        for label, reason in not_applicable:
            print(f"  - {label}: {reason}")
        print()
    if failed:
        print("FAILED")
        for label, _code in failed:
            print(f"  - {label}")
        print()
        print("READY: FAIL")
        return 1

    print("READY: PASS")
    return 0


def containers_resolved(profile_text):
    """Return 'built', 'not_applicable', or 'unknown'."""
    if "application_image: built" in profile_text:
        return "built"
    if "application_image: not_applicable" in profile_text:
        return "not_applicable"
    return "unknown"


if __name__ == "__main__":
    sys.exit(main())
